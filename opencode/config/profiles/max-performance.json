{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/master/assets/oh-my-opencode.schema.json",
  "google_auth": false,

  "agents": {
    "sisyphus": {
      "model": "anthropic/claude-opus-4-6",
      "variant": "max"
    },
    "hephaestus": {
      "model": "openai/gpt-5.4",
      "variant": "high"
    },
    "prometheus": {
      "model": "anthropic/claude-opus-4-6",
      "variant": "max"
    },
    "oracle": {
      "model": "openai/gpt-5.4",
      "variant": "high"
    },
    "librarian": {
      "model": "google/gemini-3.1-flash-lite-preview"
    },
    "explore": {
      "model": "google/gemini-3.1-flash-lite-preview"
    },
    "multimodal-looker": {
      "model": "google/gemini-3.1-pro-preview-customtools"
    },
    "metis": {
      "model": "anthropic/claude-opus-4-6",
      "variant": "max"
    },
    "momus": {
      "model": "openai/gpt-5.4",
      "variant": "high"
    },
    "atlas": {
      "model": "anthropic/claude-sonnet-4-6",
    }
  },

  "categories": {
    "quick": {
      "model": "google/gemini-3.1-flash-lite-preview"
    },
    "unspecified-low": {
      "model": "google/gemini-3.1-flash-lite-preview"
    },
    "unspecified-high": {
      "model": "anthropic/claude-opus-4-6",
      "variant": "max"
    },
    "writing": {
      "model": "anthropic/claude-sonnet-4-6"
    },
    "visual-engineering": {
      "model": "google/gemini-3.1-pro-preview",
      "variant": "high"
    },
    "ultrabrain": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh"
    },
    "deep": {
      "model": "openai/gpt-5.4",
      "variant": "high"
    },
    "artistry": {
      "model": "google/gemini-3.1-pro-preview",
      "variant": "high"
    }
  },

  "runtime_fallback": true,

  "background_task": {
    "providerConcurrency": {
      "anthropic": 3,
      "openai": 3,
      "google": 5,
      "github-copilot": 5
    },
    "modelConcurrency": {
      "anthropic/claude-opus-4-6": 2,
      "openai/gpt-5.4": 2,
      "google/gemini-3.1-flash-lite-preview": 4
    }
  },

  "lsp": {
    "pylance": {
      "command": [
        "pyright-langserver",
        "--stdio"
      ],
      "extensions": [
        "py",
        "pyi"
      ]
    },
    "clangd": {
      "command": [
        "clangd"
      ],
      "extensions": [
        "c",
        "cpp",
        "h",
        "hpp",
        "cc",
        "hh",
        "cxx"
      ]
    }
  }
}
